---
import { brand, hero, features, repos, waitlist, footer } from "../content/site";

const title = `${brand.name} — ${brand.tagline}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={brand.description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={brand.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${brand.domain}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script defer data-domain="beatly.dev" src="https://track.magicmonad.com/js/script.js"></script>
    )}
  </head>
  <body>
    <header class="nav">
      <a href="/" class="brand" aria-label={brand.name}>
        <span class="mark mark-sm" aria-hidden="true">
          <span class="bar side"></span>
          <span class="bar center"></span>
          <span class="bar side"></span>
        </span>
        <span class="wordmark">{brand.name}</span>
      </a>
      <div class="nav-right">
        <a href={repos.website.href} class="nav-link" aria-label="GitHub" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 007.86 10.92c.57.1.78-.25.78-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.3 1.2-3.1-.12-.3-.52-1.48.1-3.1 0 0 .97-.31 3.18 1.18a11 11 0 015.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.62.23 2.8.12 3.1.74.8 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.27 5.69.4.36.77 1.07.77 2.16v3.2c0 .3.2.66.79.55A11.5 11.5 0 0023.5 12C23.5 5.73 18.27.5 12 .5z"/>
          </svg>
        </a>
        <a href={hero.cta.href} class="nav-cta">{hero.cta.label}</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="mark mark-lg" role="img" aria-label={`${brand.name} logo`}>
          <span class="bar side"></span>
          <span class="bar center"></span>
          <span class="bar side"></span>
        </div>

        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>
          {hero.headline} <span class="accent">{hero.headlineAccent}</span>
        </h1>
        <p class="sub">{hero.sub}</p>

        <a href={hero.cta.href} class="cta">{hero.cta.label} →</a>
      </section>

      <section class="features" aria-label="features">
        <ul>
          {features.map((f) => (
            <li>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </li>
          ))}
        </ul>
      </section>

      <section id="open-source" class="repos" aria-label="open source">
        <h2>open source</h2>
        <p class="repos-sub">Beatly is built in the open. Two repos, one project.</p>
        <ul>
          {Object.values(repos).map((r) => (
            <li>
              <a href={r.href} target="_blank" rel="noopener">
                <div class="repo-head">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 007.86 10.92c.57.1.78-.25.78-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.3 1.2-3.1-.12-.3-.52-1.48.1-3.1 0 0 .97-.31 3.18 1.18a11 11 0 015.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.62.23 2.8.12 3.1.74.8 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.27 5.69.4.36.77 1.07.77 2.16v3.2c0 .3.2.66.79.55A11.5 11.5 0 0023.5 12C23.5 5.73 18.27.5 12 .5z"/>
                  </svg>
                  <span class="repo-name">getbeatly/{r.label}</span>
                  <span class="repo-arrow">↗</span>
                </div>
                <p>{r.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section id="waitlist" class="waitlist">
        <h2>{waitlist.heading}</h2>
        <p>{waitlist.sub}</p>
        <form
          onsubmit="event.preventDefault(); this.querySelector('button').innerText = this.dataset.success; this.querySelector('input').disabled = true;"
          data-success={waitlist.success}
        >
          <input type="email" required placeholder={waitlist.placeholder} aria-label="email" />
          <button type="submit">{waitlist.button}</button>
        </form>
      </section>

      <footer>
        <span class="foot-brand">
          <span class="mark mark-xs" aria-hidden="true">
            <span class="bar side"></span>
            <span class="bar center"></span>
            <span class="bar side"></span>
          </span>
          {brand.name}
        </span>
        <span class="foot-links">
          <a href={repos.website.href} target="_blank" rel="noopener">github</a>
          <span>© {new Date().getFullYear()} · {footer.note}</span>
        </span>
      </footer>
    </main>

    <style is:global>
      :root {
        --bg: #0A0A0A;
        --fg: #FAFAFA;
        --muted: #8a8a8a;
        --accent: #FF2E88;
        --border: rgba(250, 250, 250, 0.08);
        --card: rgba(250, 250, 250, 0.03);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-feature-settings: "ss01", "cv11";
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }

      /* ---------- three-bar mark ---------- */
      .mark {
        display: inline-flex;
        align-items: center;
        gap: var(--mark-gap, 8px);
      }
      .mark .bar {
        display: block;
        width: var(--mark-w, 16px);
        background: var(--fg);
        border-radius: 2px;
      }
      .mark .bar.side { height: var(--mark-side, 60px); }
      .mark .bar.center {
        height: var(--mark-center, 90px);
        background: var(--accent);
        animation: blink 1.1s steps(1, end) infinite;
      }
      .mark-xs { --mark-w: 3px; --mark-gap: 2px; --mark-side: 12px; --mark-center: 18px; }
      .mark-sm { --mark-w: 5px; --mark-gap: 3px; --mark-side: 20px; --mark-center: 30px; }
      .mark-lg { --mark-w: 40px; --mark-gap: 20px; --mark-side: 160px; --mark-center: 240px; }
      @keyframes blink {
        0%, 60% { opacity: 1; }
        61%, 100% { opacity: 0.15; }
      }
      @media (prefers-reduced-motion: reduce) {
        .mark .bar.center { animation: none; }
      }

      /* ---------- layout ---------- */
      .nav {
        display: flex; justify-content: space-between; align-items: center;
        max-width: 1080px; margin: 0 auto;
        padding: 24px 28px;
      }
      .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 600; letter-spacing: -0.01em; font-size: 18px; }
      .wordmark { font-size: 17px; }
      .nav-right { display: inline-flex; align-items: center; gap: 14px; }
      .nav-link {
        display: inline-grid; place-items: center;
        width: 34px; height: 34px; border-radius: 999px;
        color: var(--muted);
        transition: color .15s, background .15s;
      }
      .nav-link:hover { color: var(--fg); background: var(--card); }
      .nav-cta {
        font-size: 14px; color: var(--muted);
        border: 1px solid var(--border); padding: 8px 14px; border-radius: 999px;
        transition: color .15s, border-color .15s;
      }
      .nav-cta:hover { color: var(--fg); border-color: var(--accent); }

      main { max-width: 1080px; margin: 0 auto; padding: 0 28px 60px; }

      /* ---------- hero ---------- */
      .hero {
        display: flex; flex-direction: column; align-items: center;
        text-align: center;
        padding: 40px 0 100px;
      }
      .hero .mark-lg { margin: 40px 0 56px; }
      .eyebrow {
        margin: 0 0 18px;
        font-family: "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--accent);
      }
      .hero h1 {
        margin: 0 0 24px;
        font-size: clamp(36px, 6vw, 64px);
        line-height: 1.05; letter-spacing: -0.03em; font-weight: 600;
        max-width: 16ch;
      }
      .hero h1 .accent { color: var(--accent); }
      .sub {
        margin: 0 0 36px;
        max-width: 52ch;
        color: var(--muted);
        font-size: clamp(16px, 1.6vw, 18px);
      }
      .cta {
        display: inline-block;
        padding: 14px 24px;
        background: var(--accent);
        color: #0A0A0A;
        font-weight: 600; font-size: 15px;
        border-radius: 999px;
        transition: transform .15s, filter .15s;
      }
      .cta:hover { transform: translateY(-1px); filter: brightness(1.08); }

      /* ---------- features ---------- */
      .features { padding: 40px 0 80px; border-top: 1px solid var(--border); }
      .features ul {
        list-style: none; padding: 0; margin: 0;
        display: grid; gap: 1px;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }
      .features li {
        background: var(--bg);
        padding: 28px 24px;
      }
      .features h3 {
        margin: 0 0 10px;
        font-size: 15px; font-weight: 600; letter-spacing: -0.01em;
      }
      .features h3::before {
        content: ""; display: inline-block;
        width: 8px; height: 8px; border-radius: 2px;
        background: var(--accent); margin-right: 10px;
        vertical-align: 1px;
      }
      .features p { margin: 0; color: var(--muted); font-size: 14px; }

      /* ---------- repos ---------- */
      .repos {
        padding: 80px 0 40px;
        border-top: 1px solid var(--border);
        text-align: center;
      }
      .repos h2 {
        margin: 0 0 12px;
        font-size: clamp(24px, 3.5vw, 34px);
        letter-spacing: -0.02em; font-weight: 600;
      }
      .repos-sub { margin: 0 auto 32px; color: var(--muted); max-width: 44ch; }
      .repos ul {
        list-style: none; padding: 0; margin: 0;
        display: grid; gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        text-align: left;
      }
      .repos li a {
        display: block;
        padding: 20px 22px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        transition: border-color .15s, transform .15s;
      }
      .repos li a:hover { border-color: var(--accent); transform: translateY(-2px); }
      .repo-head {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 6px;
      }
      .repo-name {
        font-family: "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 14px; font-weight: 500;
      }
      .repo-arrow { margin-left: auto; color: var(--muted); font-size: 16px; }
      .repos li p { margin: 0; color: var(--muted); font-size: 14px; }

      /* ---------- waitlist ---------- */
      .waitlist {
        text-align: center;
        padding: 80px 0 60px;
        border-top: 1px solid var(--border);
      }
      .waitlist h2 {
        margin: 0 0 12px;
        font-size: clamp(24px, 3.5vw, 34px);
        letter-spacing: -0.02em; font-weight: 600;
      }
      .waitlist > p { margin: 0 auto 28px; max-width: 44ch; color: var(--muted); }
      .waitlist form {
        display: flex; gap: 8px; flex-wrap: wrap;
        max-width: 440px; margin: 0 auto;
      }
      .waitlist input {
        flex: 1 1 220px; min-width: 0;
        padding: 12px 16px;
        background: var(--card); color: var(--fg);
        border: 1px solid var(--border); border-radius: 10px;
        font: inherit; font-size: 14px;
        outline: none;
        transition: border-color .15s;
      }
      .waitlist input:focus { border-color: var(--accent); }
      .waitlist input:disabled { opacity: 0.5; }
      .waitlist button {
        padding: 12px 18px;
        background: var(--fg); color: #0A0A0A;
        border: 0; border-radius: 10px;
        font: inherit; font-size: 14px; font-weight: 600;
        cursor: pointer;
        transition: background .15s;
      }
      .waitlist button:hover { background: var(--accent); color: #0A0A0A; }

      /* ---------- footer ---------- */
      footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 28px 0; margin-top: 40px;
        border-top: 1px solid var(--border);
        color: var(--muted); font-size: 13px;
        flex-wrap: wrap; gap: 12px;
      }
      .foot-brand { display: inline-flex; align-items: center; gap: 8px; color: var(--fg); }
      .foot-links { display: inline-flex; align-items: center; gap: 16px; flex-wrap: wrap; }
      .foot-links a { color: var(--muted); transition: color .15s; }
      .foot-links a:hover { color: var(--accent); }
    </style>
  </body>
</html>
