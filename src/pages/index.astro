---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import { brand, hero, repos, footer } from "../content/site";

const title = `${brand.name} — ${brand.tagline}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={brand.description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={brand.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${brand.domain}`} />
    <meta property="og:image" content={`https://${brand.domain}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`https://${brand.domain}/og-image.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script defer data-domain="beatly.dev" src="https://track.magicmonad.com/js/script.js"></script>
    )}
  </head>
  <body>
    <header class="nav">
      <a href="/" class="brand" aria-label={brand.name}>
        <img src="/brand/svg/wordmark-dark.svg" alt={brand.name} class="lockup" />
      </a>
      <a href={repos.website.href} class="nav-link" target="_blank" rel="noopener">github ↗</a>
    </header>

    <main>
      <section class="hero">
        <svg class="hero-mark" viewBox="0 0 24 24" role="img" aria-label={`${brand.name} logo`} xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="8" width="4" height="8" fill="#FAFAFA"/>
          <rect x="17" y="8" width="4" height="8" fill="#FAFAFA"/>
          <rect class="hero-mark-center" x="10" y="5" width="4" height="14" fill="#FF2E88"/>
        </svg>

        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.headline} <span>{hero.headlineAccent}</span></h1>
        <p class="sub">{hero.sub}</p>
      </section>

      <section class="demo" aria-label="demo placeholder">
        <h2>live browser demo</h2>
        <div class="placeholder">Interactive demo placeholder. This area hosts real-time controls and agent-event triggers.</div>
      </section>

      <section class="install" aria-label="install">
        <h2>install</h2>
        <p class="muted">One-liner (npm):</p>
        <pre><code>npm i @beatly/core</code></pre>
        <p class="muted">One-liner (skill):</p>
        <pre><code>npx @beatly/skill@latest install</code></pre>
      </section>

      <footer>
        <a href={repos.website.href} target="_blank" rel="noopener">website repo</a>
        <a href={repos.core.href} target="_blank" rel="noopener">core repo</a>
        <span>© {new Date().getFullYear()} · {footer.note}</span>
      </footer>
    </main>

    <style is:global>
      :root {
        --bg: #0A0A0A;
        --fg: #FAFAFA;
        --muted: #8a8a8a;
        --accent: #FF2E88;
        --border: rgba(250, 250, 250, 0.08);
        --card: rgba(250, 250, 250, 0.03);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: "Geist Variable", "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1080px;
        margin: 0 auto;
        padding: 24px 28px;
      }

      .lockup { display: block; height: 28px; width: auto; }
      .nav-link { color: var(--muted); font-size: 14px; }
      .nav-link:hover { color: var(--fg); }

      main { max-width: 1080px; margin: 0 auto; padding: 0 28px 60px; }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 28px 0 48px;
      }

      .hero-mark {
        width: clamp(150px, 20vw, 220px);
        height: auto;
        margin: 20px 0 28px;
      }

      .hero-mark-center {
        transform-origin: center;
        animation: blink 1.1s steps(1, end) infinite;
      }

      @keyframes blink {
        0%, 60% { opacity: 1; }
        61%, 100% { opacity: 0.15; }
      }

      .eyebrow {
        margin: 0 0 14px;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(12px, 1vw, 15px);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      h1 {
        margin: 0 0 16px;
        font-size: clamp(44px, 7.8vw, 92px);
        line-height: 0.96;
        letter-spacing: -0.04em;
        font-weight: 760;
        max-width: 13ch;
        text-wrap: balance;
      }

      h1 span { color: var(--accent); }

      .sub {
        margin: 0;
        max-width: 52ch;
        color: var(--muted);
        font-size: clamp(16px, 1.45vw, 21px);
        line-height: 1.4;
        font-weight: 500;
      }

      .demo, .install {
        border-top: 1px solid var(--border);
        padding: 28px 0;
      }

      .install {
        text-align: center;
        padding: 52px 0;
      }

      h2 {
        margin: 0 0 16px;
        font-size: clamp(34px, 6vw, 64px);
        letter-spacing: -0.035em;
        line-height: 0.98;
        font-weight: 760;
      }

      .placeholder {
        border: 1px dashed var(--border);
        border-radius: 12px;
        padding: 24px;
        color: var(--muted);
        background: var(--card);
        font-size: clamp(17px, 1.7vw, 24px);
        line-height: 1.35;
      }

      .muted {
        margin: 10px 0;
        color: var(--muted);
        font-size: clamp(16px, 1.4vw, 20px);
        font-weight: 550;
      }

      pre {
        margin: 0 auto 14px;
        padding: 14px 16px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: rgba(0, 0, 0, 0.35);
        overflow-x: auto;
        width: fit-content;
        max-width: 100%;
      }

      code {
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(14px, 1.45vw, 22px);
        font-weight: 560;
      }

      footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 0;
        margin-top: 30px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 13px;
        gap: 12px;
        flex-wrap: wrap;
      }

      footer a:hover { color: var(--accent); }

      @media (prefers-reduced-motion: reduce) {
        .hero-mark-center { animation: none; }
      }
    </style>
  </body>
</html>
