---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import { brand, hero, repos, installs } from "../content/site";
import manifest from "../../public/samples/manifest.json";

const title = `${brand.name} — ${brand.tagline}`;

const humanGenre = (g: string) =>
  g.replace(/([a-z])([A-Z])/g, "$1 $2").replace(/\b\w/g, (c) => c.toUpperCase());

const tracks = manifest.tracks.map((t) => ({
  ...t,
  label: humanGenre(t.genre),
  src: `/samples/${t.file}`,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={brand.description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={brand.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${brand.domain}`} />
    <meta property="og:image" content={`https://${brand.domain}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`https://${brand.domain}/og-image.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script defer data-domain="beatly.dev" src="https://track.magicmonad.com/js/script.js"></script>
    )}
  </head>
  <body>
    <main>
      <div class="top-grid">
        <section class="hero">
          <div class="hero-brand">
            <svg class="hero-mark" viewBox="0 0 24 24" role="img" aria-label={`${brand.name} logo`} xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="8" width="4" height="8" fill="#FAFAFA"/>
              <rect x="17" y="8" width="4" height="8" fill="#FAFAFA"/>
              <rect class="hero-mark-center" x="10" y="5" width="4" height="14" fill="#FF2E88"/>
            </svg>
            <span class="hero-name">beatly</span>
          </div>

          <p class="eyebrow">{hero.eyebrow}</p>
          <h1>{hero.headline} <span>{hero.headlineAccent}</span></h1>
          <p class="sub">{hero.sub}</p>
        </section>

        <aside class="hero-side">
          <section class="repo-links" aria-label="github links">
            <a href={repos.core.href} target="_blank" rel="noopener" class="repo-link-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 007.86 10.92c.57.1.78-.25.78-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.3 1.2-3.1-.12-.3-.52-1.48.1-3.1 0 0 .97-.31 3.18 1.18a11 11 0 015.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.62.23 2.8.12 3.1.74.8 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.27 5.69.4.36.77 1.07.77 2.16v3.2c0 .3.2.66.79.55A11.5 11.5 0 0023.5 12C23.5 5.73 18.27.5 12 .5z"/>
              </svg>
              <span>getbeatly/beatly</span>
            </a>
          </section>

          <section class="player" aria-label="genre samples" data-player>
            <div class="player-head">
              <p class="player-eyebrow">preview genres</p>

            </div>

            <div class="player-main">
              <button class="player-btn player-nav" type="button" data-prev aria-label="Previous sample">‹</button>
              <button class="player-btn player-play" type="button" data-toggle aria-label="Play sample">
                <span data-icon-play>▶</span>
                <span data-icon-pause hidden>❚❚</span>
              </button>
              <button class="player-btn player-nav" type="button" data-next aria-label="Next sample">›</button>
              <div class="player-info">
                <p class="player-genre" data-genre>{tracks[0].label}</p>
                <p class="player-sub"><span data-variant>{tracks[0].variant}</span> · <span data-bpm>{tracks[0].bpm}</span> BPM</p>
              </div>
            </div>

            <div class="player-progress" data-progress>
              <div class="player-progress-fill" data-progress-fill></div>
            </div>

            <div class="player-chips">
              {tracks.map((t, i) => (
                <button type="button" class="player-chip" data-chip={i} data-genre-id={t.genre}>{t.label}</button>
              ))}
            </div>

            <audio data-audio preload="none"></audio>
          </section>
        </aside>
      </div>

      <div class="below-hero">
        <section class="install" aria-label="install">
          <p class="muted">install for your agent</p>
          {installs.map((item) => (
            <div class="install-row">
              <p class="install-label">{item.label}</p>
              <pre><code>{item.command}</code></pre>
              <p class="install-hint">{item.hint}</p>
            </div>
          ))}
        </section>
      </div>
    </main>

    <script define:vars={{ tracks }}>
      (() => {
        const root = document.querySelector("[data-player]");
        if (!root) return;
        const audio = root.querySelector("[data-audio]");
        const playBtn = root.querySelector("[data-toggle]");
        const iconPlay = root.querySelector("[data-icon-play]");
        const iconPause = root.querySelector("[data-icon-pause]");
        const prevBtn = root.querySelector("[data-prev]");
        const nextBtn = root.querySelector("[data-next]");
        const genreEl = root.querySelector("[data-genre]");
        const variantEl = root.querySelector("[data-variant]");
        const bpmEl = root.querySelector("[data-bpm]");
        const fill = root.querySelector("[data-progress-fill]");
        const progress = root.querySelector("[data-progress]");
        const chips = Array.from(root.querySelectorAll("[data-chip]"));

        let current = 0;

        const load = (i, autoplay) => {
          current = (i + tracks.length) % tracks.length;
          const t = tracks[current];
          audio.src = t.src;
          genreEl.textContent = t.label;
          variantEl.textContent = t.variant;
          bpmEl.textContent = t.bpm;
          chips.forEach((c, ci) => c.setAttribute("aria-current", ci === current ? "true" : "false"));
          fill.style.width = "0%";
          if (autoplay) audio.play().catch(() => {});
        };

        const setPlaying = (playing) => {
          iconPlay.hidden = playing;
          iconPause.hidden = !playing;
          playBtn.setAttribute("aria-label", playing ? "Pause sample" : "Play sample");
        };

        playBtn.addEventListener("click", () => {
          if (audio.paused) audio.play().catch(() => {});
          else audio.pause();
        });
        prevBtn.addEventListener("click", () => load(current - 1, !audio.paused));
        nextBtn.addEventListener("click", () => load(current + 1, !audio.paused));
        chips.forEach((chip, i) => chip.addEventListener("click", () => load(i, true)));

        progress.addEventListener("click", (e) => {
          if (!audio.duration) return;
          const rect = progress.getBoundingClientRect();
          const ratio = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
          audio.currentTime = ratio * audio.duration;
        });

        audio.addEventListener("play", () => setPlaying(true));
        audio.addEventListener("pause", () => setPlaying(false));
        audio.addEventListener("ended", () => load(current + 1, true));
        audio.addEventListener("timeupdate", () => {
          if (!audio.duration) return;
          fill.style.width = ((audio.currentTime / audio.duration) * 100).toFixed(2) + "%";
        });

        load(Math.floor(Math.random() * tracks.length), true);

        // Browsers block autoplay without a gesture — start on first interaction.
        const kick = () => {
          if (audio.paused) audio.play().catch(() => {});
          window.removeEventListener("pointerdown", kick);
          window.removeEventListener("keydown", kick);
          window.removeEventListener("scroll", kick);
          window.removeEventListener("touchstart", kick);
        };
        window.addEventListener("pointerdown", kick, { once: false });
        window.addEventListener("keydown", kick, { once: false });
        window.addEventListener("scroll", kick, { once: false, passive: true });
        window.addEventListener("touchstart", kick, { once: false, passive: true });
      })();

      document.querySelectorAll(".install pre").forEach((block) => {
        block.addEventListener("click", () => {
          const code = block.querySelector("code");
          if (!code) return;

          const selection = window.getSelection();
          if (!selection) return;

          const range = document.createRange();
          range.selectNodeContents(code);
          selection.removeAllRanges();
          selection.addRange(range);
        });
      });
    </script>

    <style is:global>
      :root {
        --bg: #0A0A0A;
        --fg: #FAFAFA;
        --muted: #8a8a8a;
        --accent: #FF2E88;
        --border: rgba(250, 250, 250, 0.08);
        --card: rgba(250, 250, 250, 0.03);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        background:
          radial-gradient(1200px 760px at 6% -10%, rgba(255, 46, 136, 0.30), transparent 58%),
          radial-gradient(980px 680px at 100% 4%, rgba(108, 92, 255, 0.24), transparent 60%),
          radial-gradient(1100px 740px at 74% 100%, rgba(0, 206, 255, 0.18), transparent 62%),
          linear-gradient(160deg, #07070a 0%, #0c0c16 45%, #09090d 100%);
        color: var(--fg);
        font-family: "Geist Variable", "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
      }

      body::before {
        background:
          radial-gradient(2px 2px at 8% 14%, rgba(255, 255, 255, 0.46), transparent 74%),
          radial-gradient(1.5px 1.5px at 16% 58%, rgba(255, 255, 255, 0.34), transparent 72%),
          radial-gradient(1px 1px at 24% 76%, rgba(255, 255, 255, 0.28), transparent 70%),
          radial-gradient(2px 2px at 33% 30%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(1.5px 1.5px at 44% 84%, rgba(255, 255, 255, 0.30), transparent 72%),
          radial-gradient(2px 2px at 58% 10%, rgba(255, 255, 255, 0.44), transparent 74%),
          radial-gradient(1.5px 1.5px at 66% 52%, rgba(255, 255, 255, 0.32), transparent 72%),
          radial-gradient(2px 2px at 76% 24%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(1px 1px at 82% 68%, rgba(255, 255, 255, 0.30), transparent 70%),
          radial-gradient(2px 2px at 90% 38%, rgba(255, 255, 255, 0.46), transparent 74%),
          radial-gradient(1.5px 1.5px at 94% 80%, rgba(255, 255, 255, 0.34), transparent 72%);
        opacity: 1;
        animation: sparkleTwinkle 5.2s ease-in-out infinite alternate;
        z-index: 0;
      }

      body::after {
        background:
          radial-gradient(circle at 20% 20%, rgba(255, 46, 136, 0.16), transparent 40%),
          radial-gradient(circle at 78% 68%, rgba(0, 206, 255, 0.16), transparent 42%),
          radial-gradient(circle at 58% 36%, rgba(130, 108, 255, 0.14), transparent 38%);
        mix-blend-mode: screen;
        opacity: 1;
        filter: blur(28px);
        z-index: 0;
      }

      @keyframes sparkleTwinkle {
        0% { opacity: 0.68; transform: translateY(0px) scale(1); }
        50% { opacity: 1; transform: translateY(-3px) scale(1.02); }
        100% { opacity: 0.72; transform: translateY(2px) scale(0.99); }
      }

      a { color: inherit; text-decoration: none; }

      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 28px 60px;
        position: relative;
        z-index: 1;
      }

      .top-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(240px, 0.8fr);
        gap: 36px;
        align-items: start;
        padding: 32px 0 0;
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
      }

      .hero-side {
        padding-top: 86px;
        display: grid;
        gap: 16px;
      }

      .player {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--card);
        padding: 16px 16px 14px;
        display: grid;
        gap: 12px;
      }

      .player-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
      }

      .player-eyebrow {
        margin: 0;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      .player-meta {
        margin: 0;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 11px;
        color: var(--muted);
      }

      .player-main {
        display: grid;
        grid-template-columns: auto auto auto 1fr;
        align-items: center;
        gap: 8px;
      }

      .player-btn {
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        color: var(--fg);
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: border-color .15s, background .15s, transform .15s;
        font-family: inherit;
      }

      .player-btn:hover {
        border-color: rgba(255, 255, 255, 0.26);
        background: rgba(255, 255, 255, 0.08);
      }

      .player-nav {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        font-size: 20px;
        line-height: 1;
        padding: 0;
      }

      .player-play {
        width: 44px;
        height: 44px;
        border-radius: 999px;
        background: var(--accent);
        border-color: transparent;
        color: #0A0A0A;
        font-size: 14px;
      }

      .player-play:hover {
        background: #ff4d9a;
        border-color: transparent;
        transform: translateY(-1px);
      }

      .player-play [hidden] { display: none; }

      .player-info {
        min-width: 0;
        padding-left: 4px;
      }

      .player-genre {
        margin: 0;
        font-size: 15px;
        font-weight: 650;
        letter-spacing: -0.01em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .player-sub {
        margin: 2px 0 0;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 11px;
        color: var(--muted);
      }

      .player-progress {
        height: 4px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
      }

      .player-progress-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--accent), #6c5cff);
        transition: width .1s linear;
      }

      .player-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .player-chip {
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 11px;
        padding: 5px 9px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
        cursor: pointer;
        transition: color .15s, border-color .15s, background .15s;
      }

      .player-chip:hover {
        color: var(--fg);
        border-color: rgba(255, 255, 255, 0.22);
      }

      .player-chip[aria-current="true"] {
        color: #0A0A0A;
        background: var(--accent);
        border-color: transparent;
        font-weight: 700;
      }

      .below-hero {
        display: grid;
        gap: 20px;
        margin-top: 40px;
      }

      @media (max-width: 780px) {
        .top-grid {
          grid-template-columns: 1fr;
          gap: 20px;
        }

        .hero-side {
          padding-top: 0;
        }
      }



      .hero-brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        margin: 6px 0 16px;
      }

      .hero-mark {
        width: clamp(38px, 4.8vw, 56px);
        height: auto;
        margin: 0;
      }

      .hero-name {
        font-size: clamp(38px, 4.8vw, 56px);
        line-height: 1;
        font-weight: 780;
        letter-spacing: -0.03em;
      }

      .hero-mark-center {
        transform-origin: center;
        animation: blink 1.1s steps(1, end) infinite;
      }

      @keyframes blink {
        0%, 60% { opacity: 1; }
        61%, 100% { opacity: 0.15; }
      }

      .eyebrow {
        margin: 0 0 14px;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(12px, 1vw, 15px);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      h1 {
        margin: 0 0 14px;
        font-size: clamp(38px, 6.4vw, 74px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 740;
        max-width: 14ch;
        text-wrap: balance;
      }

      h1 span { color: var(--accent); }

      .sub {
        margin: 0;
        max-width: 54ch;
        color: var(--muted);
        font-size: clamp(15px, 1.25vw, 18px);
        line-height: 1.45;
        font-weight: 500;
      }

      .install {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--card);
        padding: 20px;
      }

      .install {
        text-align: left;
        padding: 22px 20px;
      }

      .install pre,
      .install code {
        text-align: left;
      }

      .install pre {
        width: 100%;
        margin: 6px 0 4px;
      }

      .install-row + .install-row {
        margin-top: 14px;
      }

      .install-label {
        margin: 0 0 2px;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      .install-hint {
        margin: 2px 0 0;
        color: var(--muted);
        font-size: 12px;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
      }

      .install-note {
        margin: 16px 0 0;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: rgba(255, 46, 136, 0.08);
        color: var(--muted);
        font-size: 12.5px;
        line-height: 1.5;
      }

      .install-note strong {
        color: var(--fg);
      }

      .muted {
        margin: 10px 0;
        color: var(--muted);
        font-size: clamp(16px, 1.4vw, 20px);
        font-weight: 550;
      }

      pre {
        margin: 0 0 6px;
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: rgba(0, 0, 0, 0.35);
        width: 100%;
        max-width: 100%;
        overflow: hidden;
        white-space: normal;
        word-break: break-word;
      }

      .install pre code {
        display: block;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
      }

      .install pre { cursor: pointer; }

      .repo-links {
        display: grid;
        gap: 10px;
      }

      .repo-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 13px 14px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.03);
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 14px;
        color: var(--fg);
        transition: border-color .15s, background .15s, transform .15s;
      }

      .repo-link-btn:hover {
        border-color: rgba(255, 255, 255, 0.24);
        background: rgba(255, 255, 255, 0.07);
        transform: translateY(-1px);
      }

      code {
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(13px, 1.15vw, 17px);
        font-weight: 560;
      }



      @media (prefers-reduced-motion: reduce) {
        .hero-mark-center { animation: none; }
        body::before { animation: none; }
      }
    </style>
  </body>
</html>
