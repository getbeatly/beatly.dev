---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import { brand, hero, repos, footer } from "../content/site";

const title = `${brand.name} — ${brand.tagline}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={brand.description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={brand.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${brand.domain}`} />
    <meta property="og:image" content={`https://${brand.domain}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`https://${brand.domain}/og-image.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script defer data-domain="beatly.dev" src="https://track.magicmonad.com/js/script.js"></script>
    )}
  </head>
  <body>
    <header class="nav">
      <a href={repos.website.href} class="nav-link" target="_blank" rel="noopener">github ↗</a>
    </header>

    <main>
      <div class="top-grid">
        <section class="hero">
          <div class="hero-brand">
            <svg class="hero-mark" viewBox="0 0 24 24" role="img" aria-label={`${brand.name} logo`} xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="8" width="4" height="8" fill="#FAFAFA"/>
              <rect x="17" y="8" width="4" height="8" fill="#FAFAFA"/>
              <rect class="hero-mark-center" x="10" y="5" width="4" height="14" fill="#FF2E88"/>
            </svg>
            <span class="hero-name">beatly</span>
          </div>

          <p class="eyebrow">{hero.eyebrow}</p>
          <h1>{hero.headline} <span>{hero.headlineAccent}</span></h1>
          <p class="sub">{hero.sub}</p>
        </section>

        <aside class="side">
          <section class="demo" aria-label="demo placeholder">
            <button class="demo-play" type="button" aria-label="Play demo">
              <span class="demo-play-icon">▶</span>
            </button>
          </section>

          <section class="install" aria-label="install">
            <p class="muted">install library</p>
            <pre><code>npm i @beatly/core</code></pre>
            <p class="muted">install skill</p>
            <pre><code>npx @beatly/skill install</code></pre>
          </section>
        </aside>
      </div>

      <footer>
        <a href={repos.website.href} target="_blank" rel="noopener">website repo</a>
        <a href={repos.core.href} target="_blank" rel="noopener">core repo</a>
        <span>© {new Date().getFullYear()} · {footer.note}</span>
      </footer>
    </main>

    <script>
      document.querySelectorAll(".install pre").forEach((block) => {
        block.addEventListener("click", () => {
          const code = block.querySelector("code");
          if (!code) return;

          const selection = window.getSelection();
          if (!selection) return;

          const range = document.createRange();
          range.selectNodeContents(code);
          selection.removeAllRanges();
          selection.addRange(range);
        });
      });
    </script>

    <style is:global>
      :root {
        --bg: #0A0A0A;
        --fg: #FAFAFA;
        --muted: #8a8a8a;
        --accent: #FF2E88;
        --border: rgba(250, 250, 250, 0.08);
        --card: rgba(250, 250, 250, 0.03);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        background:
          radial-gradient(1200px 760px at 6% -10%, rgba(255, 46, 136, 0.30), transparent 58%),
          radial-gradient(980px 680px at 100% 4%, rgba(108, 92, 255, 0.24), transparent 60%),
          radial-gradient(1100px 740px at 74% 100%, rgba(0, 206, 255, 0.18), transparent 62%),
          linear-gradient(160deg, #07070a 0%, #0c0c16 45%, #09090d 100%);
        color: var(--fg);
        font-family: "Geist Variable", "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
      }

      body::before {
        background:
          radial-gradient(2px 2px at 8% 14%, rgba(255, 255, 255, 0.46), transparent 74%),
          radial-gradient(1.5px 1.5px at 16% 58%, rgba(255, 255, 255, 0.34), transparent 72%),
          radial-gradient(1px 1px at 24% 76%, rgba(255, 255, 255, 0.28), transparent 70%),
          radial-gradient(2px 2px at 33% 30%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(1.5px 1.5px at 44% 84%, rgba(255, 255, 255, 0.30), transparent 72%),
          radial-gradient(2px 2px at 58% 10%, rgba(255, 255, 255, 0.44), transparent 74%),
          radial-gradient(1.5px 1.5px at 66% 52%, rgba(255, 255, 255, 0.32), transparent 72%),
          radial-gradient(2px 2px at 76% 24%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(1px 1px at 82% 68%, rgba(255, 255, 255, 0.30), transparent 70%),
          radial-gradient(2px 2px at 90% 38%, rgba(255, 255, 255, 0.46), transparent 74%),
          radial-gradient(1.5px 1.5px at 94% 80%, rgba(255, 255, 255, 0.34), transparent 72%);
        opacity: 1;
        animation: sparkleTwinkle 5.2s ease-in-out infinite alternate;
        z-index: 0;
      }

      body::after {
        background:
          radial-gradient(circle at 20% 20%, rgba(255, 46, 136, 0.16), transparent 40%),
          radial-gradient(circle at 78% 68%, rgba(0, 206, 255, 0.16), transparent 42%),
          radial-gradient(circle at 58% 36%, rgba(130, 108, 255, 0.14), transparent 38%);
        mix-blend-mode: screen;
        opacity: 1;
        filter: blur(28px);
        z-index: 0;
      }

      @keyframes sparkleTwinkle {
        0% { opacity: 0.68; transform: translateY(0px) scale(1); }
        50% { opacity: 1; transform: translateY(-3px) scale(1.02); }
        100% { opacity: 0.72; transform: translateY(2px) scale(0.99); }
      }

      a { color: inherit; text-decoration: none; }

      .nav {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        max-width: 1080px;
        margin: 0 auto;
        padding: 24px 28px;
        position: relative;
        z-index: 1;
      }

      .nav-link { color: var(--muted); font-size: 14px; }
      .nav-link:hover { color: var(--fg); }

      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 28px 60px;
        position: relative;
        z-index: 1;
      }

      .top-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
        gap: 36px;
        align-items: start;
        padding: 22px 0 10px;
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
        padding: 10px 0 0;
      }

      .hero-brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        margin: 6px 0 16px;
      }

      .hero-mark {
        width: clamp(38px, 4.8vw, 56px);
        height: auto;
        margin: 0;
      }

      .hero-name {
        font-size: clamp(38px, 4.8vw, 56px);
        line-height: 1;
        font-weight: 780;
        letter-spacing: -0.03em;
      }

      .hero-mark-center {
        transform-origin: center;
        animation: blink 1.1s steps(1, end) infinite;
      }

      @keyframes blink {
        0%, 60% { opacity: 1; }
        61%, 100% { opacity: 0.15; }
      }

      .eyebrow {
        margin: 0 0 14px;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(12px, 1vw, 15px);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      h1 {
        margin: 0 0 14px;
        font-size: clamp(38px, 6.4vw, 74px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 740;
        max-width: 14ch;
        text-wrap: balance;
      }

      h1 span { color: var(--accent); }

      .sub {
        margin: 0;
        max-width: 54ch;
        color: var(--muted);
        font-size: clamp(15px, 1.25vw, 18px);
        line-height: 1.45;
        font-weight: 500;
      }

      .side {
        display: grid;
        gap: 16px;
        padding-top: 36px;
      }

      .demo,
      .install {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--card);
        padding: 20px;
      }

      .install {
        text-align: center;
        padding: 26px 20px;
      }

      .install pre,
      .install code {
        text-align: center;
      }

      .install pre {
        width: 100%;
      }

      .demo {
        min-height: 180px;
        display: grid;
        place-items: center;
      }

      .demo-play {
        width: 94px;
        height: 94px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--fg);
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: transform .15s, border-color .15s, background .15s;
      }

      .demo-play:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.26);
        background: rgba(255, 255, 255, 0.06);
      }

      .demo-play-icon {
        font-size: 34px;
        line-height: 1;
        margin-left: 4px;
      }

      .muted {
        margin: 10px 0;
        color: var(--muted);
        font-size: clamp(16px, 1.4vw, 20px);
        font-weight: 550;
      }

      pre {
        margin: 0 auto 14px;
        padding: 14px 16px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: rgba(0, 0, 0, 0.35);
        overflow-x: auto;
        width: fit-content;
        max-width: 100%;
      }

      .install pre { cursor: pointer; }

      code {
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: clamp(14px, 1.45vw, 22px);
        font-weight: 560;
      }

      footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 0;
        margin-top: 30px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 13px;
        gap: 12px;
        flex-wrap: wrap;
      }

      footer a:hover { color: var(--accent); }

      @media (max-width: 980px) {
        .top-grid {
          grid-template-columns: 1fr;
          gap: 20px;
        }

        .hero {
          padding-top: 0;
        }

        .side {
          padding-top: 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-mark-center { animation: none; }
        body::before { animation: none; }
      }
    </style>
  </body>
</html>
