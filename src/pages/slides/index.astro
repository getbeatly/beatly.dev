---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import { brand } from "../../content/site";
import slidesMarkdown from "../../content/slides/hackathon.md?raw";

const title = `Slides — ${brand.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Beatly hackathon presentation slides" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Beatly hackathon presentation slides" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${brand.domain}/slides/`} />
    <meta property="og:image" content={`https://${brand.domain}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`https://${brand.domain}/og-image.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="https://unpkg.com/reveal.js@5/dist/reveal.css" />
    <title>{title}</title>
  </head>
  <body>
    <div class="deck-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <svg class="brand-mark" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="8" width="4" height="8" fill="#FAFAFA"/>
            <rect x="17" y="8" width="4" height="8" fill="#FAFAFA"/>
            <rect class="brand-mark-center" x="10" y="5" width="4" height="14" fill="#FF2E88"/>
          </svg>
          <span>beatly</span>
        </a>
        <nav class="toplinks">
          <a href="/">home</a>
          <a href="https://beatly.dev" target="_blank" rel="noopener">website</a>
          <a href="https://github.com/getbeatly/beatly" target="_blank" rel="noopener">github</a>
        </nav>
      </header>

      <div class="reveal">
        <div class="slides">
          <section data-markdown data-separator="^---$" data-separator-vertical="^--$">
            <textarea data-template>{slidesMarkdown}</textarea>
          </section>
        </div>
      </div>
    </div>

    <script src="https://unpkg.com/reveal.js@5/dist/reveal.js"></script>
    <script src="https://unpkg.com/reveal.js@5/plugin/markdown/markdown.js"></script>
    <script>
      Reveal.initialize({
        hash: true,
        controls: true,
        progress: true,
        center: true,
        transition: "fade",
        backgroundTransition: "fade",
        plugins: [ RevealMarkdown ]
      });
    </script>

    <style is:global>
      :root {
        --bg: #0A0A0A;
        --fg: #FAFAFA;
        --muted: #8a8a8a;
        --accent: #FF2E88;
        --border: rgba(250, 250, 250, 0.08);
        --card: rgba(250, 250, 250, 0.04);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        background:
          radial-gradient(1200px 760px at 6% -10%, rgba(255, 46, 136, 0.30), transparent 58%),
          radial-gradient(980px 680px at 100% 4%, rgba(108, 92, 255, 0.24), transparent 60%),
          radial-gradient(1100px 740px at 74% 100%, rgba(0, 206, 255, 0.18), transparent 62%),
          linear-gradient(160deg, #07070a 0%, #0c0c16 45%, #09090d 100%);
        color: var(--fg);
        font-family: "Geist Variable", "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        min-height: 100vh;
        overflow: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
      }

      body::before {
        background:
          radial-gradient(2px 2px at 8% 14%, rgba(255, 255, 255, 0.46), transparent 74%),
          radial-gradient(1.5px 1.5px at 16% 58%, rgba(255, 255, 255, 0.34), transparent 72%),
          radial-gradient(2px 2px at 33% 30%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(1.5px 1.5px at 44% 84%, rgba(255, 255, 255, 0.30), transparent 72%),
          radial-gradient(2px 2px at 58% 10%, rgba(255, 255, 255, 0.44), transparent 74%),
          radial-gradient(2px 2px at 76% 24%, rgba(255, 255, 255, 0.42), transparent 74%),
          radial-gradient(2px 2px at 90% 38%, rgba(255, 255, 255, 0.46), transparent 74%);
        opacity: .9;
        z-index: 0;
      }

      body::after {
        background:
          radial-gradient(circle at 20% 20%, rgba(255, 46, 136, 0.16), transparent 40%),
          radial-gradient(circle at 78% 68%, rgba(0, 206, 255, 0.16), transparent 42%),
          radial-gradient(circle at 58% 36%, rgba(130, 108, 255, 0.14), transparent 38%);
        mix-blend-mode: screen;
        filter: blur(28px);
        z-index: 0;
      }

      .deck-shell {
        position: relative;
        z-index: 1;
        height: 100vh;
      }

      .topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 22px;
        z-index: 20;
        pointer-events: none;
      }

      .brand,
      .toplinks a {
        pointer-events: auto;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--fg);
        text-decoration: none;
        font-weight: 780;
        letter-spacing: -0.03em;
      }

      .brand-mark { width: 26px; height: 26px; }
      .brand-mark-center {
        transform-origin: center;
        animation: blink 1.1s steps(1, end) infinite;
      }
      @keyframes blink {
        0%, 60% { opacity: 1; }
        61%, 100% { opacity: 0.15; }
      }

      .toplinks {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .toplinks a {
        color: var(--fg);
        text-decoration: none;
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 12px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
      }

      .reveal {
        height: 100vh;
        color: var(--fg);
      }

      .reveal .slides {
        text-align: left;
      }

      .reveal .slides section {
        padding: 44px;
        border: 1px solid var(--border);
        border-radius: 28px;
        background: rgba(10, 10, 10, 0.46);
        backdrop-filter: blur(14px);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      }

      .reveal h1,
      .reveal h2,
      .reveal h3 {
        margin: 0 0 18px;
        color: var(--fg);
        letter-spacing: -0.04em;
        line-height: 0.96;
        text-transform: none;
      }

      .reveal h1 { font-size: clamp(2.7rem, 7vw, 5.8rem); max-width: 10ch; }
      .reveal h2 { font-size: clamp(2rem, 4.4vw, 4rem); max-width: 12ch; }
      .reveal h3 { font-size: clamp(1.1rem, 2vw, 1.5rem); color: var(--accent); }

      .reveal p,
      .reveal li,
      .reveal ol {
        font-size: clamp(1.05rem, 1.6vw, 1.5rem);
        line-height: 1.45;
      }

      .reveal p {
        margin: 0 0 16px;
        color: rgba(250, 250, 250, 0.9);
        max-width: 54rem;
      }

      .reveal strong { color: var(--accent); font-weight: 780; }

      .reveal ul,
      .reveal ol {
        display: grid;
        gap: 12px;
        margin: 20px 0 0 0.2em;
        padding-left: 1.1em;
      }

      .reveal ul li::marker,
      .reveal ol li::marker {
        color: var(--accent);
      }

      .reveal a {
        color: var(--fg);
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,.24);
      }

      .reveal img {
        display: block;
        max-width: min(62vw, 760px);
        max-height: 38vh;
        width: auto;
        height: auto;
        margin: 18px 0 0;
        border: 0;
        box-shadow: none;
        background: transparent;
      }

      .reveal .progress {
        color: var(--accent);
        height: 4px;
      }

      .reveal .controls {
        color: var(--fg);
      }

      .slide-links {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .slide-links a {
        display: inline-flex;
        align-items: center;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,.04);
        font-family: "Geist Mono Variable", "Geist Mono", ui-monospace, Menlo, monospace;
        font-size: 13px;
      }

      @media (max-width: 900px) {
        .topbar {
          position: static;
          padding-bottom: 0;
        }

        body { overflow: auto; }
        .deck-shell,
        .reveal { height: auto; min-height: 100vh; }
        .reveal .slides section { padding: 28px; }
      }
    </style>
  </body>
</html>
